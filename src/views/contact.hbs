<section
  id="contact"
  class="bg-gray-100 flex-col w-full grow text-gray-800 flex items-center justify-center py-20 gap-8"
>
  <h1 class="text-4xl font-extrabold text-gray-800">
    Contact Me
  </h1>

  <form
    class="w-full max-w-md bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col gap-5"
  >
    <!-- Name -->
    <div class="flex flex-col gap-2">
      <label for="inputName" class="font-semibold text-sm text-gray-700">
        Name
      </label>
      <input
        type="text"
        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all bg-gray-50"
        id="inputName"
        placeholder="John Doe..."
        required
      />
    </div>

    <!-- Email -->
    <div class="flex flex-col gap-2">
      <label for="inputEmail" class="font-semibold text-sm text-gray-700">
        Email Address
      </label>
      <input
        type="email"
        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all bg-gray-50"
        id="inputEmail"
        placeholder="example@mail.com"
        required
      />
    </div>

    <!-- Message -->
    <div class="flex flex-col gap-2">
      <label for="inputMessage" class="font-semibold text-sm text-gray-700">
        Message
      </label>
      <textarea
        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all bg-gray-50 resize-none"
        id="inputMessage"
        rows="4"
        placeholder="Write your message..."
        required
      ></textarea>
    </div>

    <!-- Buttons -->
    <div class="flex gap-4 mt-2">
      <a
        href="/"
        class="w-1/3 flex justify-center items-center py-3.5 px-6 border-2 border-gray-300 rounded-full hover:bg-gray-800 hover:border-gray-800 hover:text-white text-gray-800 hover:shadow-xl duration-300 transition-all font-semibold"
      >
        Back
      </a>
      <button
        type="submit"
        class="w-2/3 py-3.5 px-6 bg-gray-800 rounded-full text-white hover:cursor-pointer hover:-translate-y-1 hover:shadow-xl hover:bg-gray-800 duration-300 transition-all font-semibold"
      >
        Submit
      </button>
    </div>
  </form>
</section>