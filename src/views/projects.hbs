<section
  id="form"
  class="bg-gray-100 flex flex-col justify-center items-center py-12 px-4 gap-8"
>
  <h1 class="font-bold text-center text-3xl">
    ADD MY PROJECT
  </h1>
  <form
    id="projectForm"
    class="bg-white border-0 shadow-sm rounded-2xl p-8 w-11/12 md:w-8/12 lg:w-5/12"
  >
    <!-- Project Name -->
    <div class="mb-4">
      <label for="projectName" class="block font-semibold mb-2 text-sm">
        Project Name
      </label>
      <input
        type="text"
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-800"
        name="projectName"
        id="projectName"
        required
      />
    </div>

    <!-- Dates -->
    <div class="flex flex-col md:flex-row gap-4 mb-4">
      <div class="w-full md:w-1/2">
        <label for="projectStartDate" class="block font-semibold mb-2 text-sm">
          Start Date
        </label>
        <input
          type="date"
          class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-800 hover:cursor-pointer"
          name="projectStartDate"
          id="projectStartDate"
          required
        />
      </div>
      <div class="w-full md:w-1/2">
        <label for="projectEndDate" class="block font-semibold mb-2 text-sm">
          End Date
        </label>
        <input
          type="date"
          class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-800 hover:cursor-pointer"
          name="projectEndDate"
          id="projectEndDate"
          required
        />
      </div>
    </div>

    <!-- Description -->
    <div class="mb-4">
      <label for="projectDescription" class="block font-semibold mb-2 text-sm">
        Description
      </label>
      <textarea
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm resize-none focus:outline-none focus:ring-2 focus:ring-gray-800"
        rows="4"
        name="projectDescription"
        id="projectDescription"
        required
      ></textarea>
    </div>

    <!-- Technologies -->
    <div class="mb-4">
      <label class="block font-semibold mb-2 text-sm">
        Technologies
      </label>
      <div class="grid grid-cols-2 gap-y-2 gap-x-4">
        <div>
          <div class="flex items-center gap-2">
            <input
              class="w-4 h-4 text-gray-800 bg-gray-100 border-gray-300 rounded focus:ring-gray-800 focus:ring-2 m-0 cursor-pointer"
              type="checkbox"
              id="nodejs"
              value="Node JS"
            />
            <label class="text-gray-600 cursor-pointer text-sm" for="nodejs">
              Node JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-2">
            <input
              class="w-4 h-4 text-gray-800 bg-gray-100 border-gray-300 rounded focus:ring-gray-800 focus:ring-2 m-0 cursor-pointer"
              type="checkbox"
              id="nextjs"
              value="Next JS"
            />
            <label class="text-gray-600 cursor-pointer text-sm" for="nextjs">
              Next JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-2">
            <input
              class="w-4 h-4 text-gray-800 bg-gray-100 border-gray-300 rounded focus:ring-gray-800 focus:ring-2 m-0 cursor-pointer"
              type="checkbox"
              id="reactjs"
              value="React JS"
            />
            <label class="text-gray-600 cursor-pointer text-sm" for="reactjs">
              React JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-2">
            <input
              class="w-4 h-4 text-gray-800 bg-gray-100 border-gray-300 rounded focus:ring-gray-800 focus:ring-2 m-0 cursor-pointer"
              type="checkbox"
              id="typescript"
              value="Typescript"
            />
            <label
              class="text-gray-600 cursor-pointer text-sm"
              for="typescript"
            >
              TypeScript
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Image -->
    <div class="mb-6">
      <label for="projectImage" class="block font-semibold mb-2 text-sm">
        Upload Image
      </label>
      <div
        class="relative shadow-sm rounded-md overflow-hidden border border-gray-300 bg-white"
      >
        <input
          type="file"
          class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-semibold file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200 cursor-pointer"
          name="projectImage"
          id="projectImage"
        />
      </div>
      <p class="text-gray-500 text-xs mt-2">
        *Upload an image in JPG or PNG format
      </p>
    </div>

    <!-- Buttons -->
    <div class="flex justify-end mt-4">
      <button
        type="submit"
        class="bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-full px-12 py-2 w-full shadow-sm transition-colors duration-200 hover:cursor-pointer"
      >
        Submit
      </button>
    </div>
  </form>
</section>

<section id="projects" class="bg-white py-12">
  <div class="container mx-auto">
    <!-- Section Title -->
    <div class="flex flex-col items-center justify-center mb-12">
      <h2 class="font-bold text-center text-3xl mb-2">
        MY PROJECTS
      </h2>
      <div class="w-16 h-1 bg-gray-800 rounded"></div>
    </div>
    <!-- Search Input -->
    <div class="flex justify-end mb-10 w-full md:w-1/2 lg:w-1/3 ml-auto">
      <div class="flex items-center border-b-2 border-gray-300 pb-2 w-full">
        <i class="fa-solid fa-magnifying-glass text-gray-500 mx-3"></i>
        <input
          type="text"
          class="w-full bg-transparent border-none focus:outline-none text-gray-700 placeholder-gray-500 p-0 m-0 shadow-none text-sm"
          id="searchProject"
          placeholder="Search..."
        />
      </div>
    </div>

    <div
      id="projectContainer"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6"
    >
      <!-- Project Card Item -->
    </div>
  </div>
</section>

<!-- HTML Template untuk Rendering Card di JS (Dipisah ke Partials) -->
{{> projectCard}}

<!-- Modal Body -->
<div
  id="projectModal"
  class="hidden fixed inset-0 w-full h-full bg-gray-800/50 justify-center items-center z-50"
>
  <!-- Modal Content -->
  <div
    class="bg-white rounded-2xl p-6 shadow-xl w-full mx-4 max-w-2xl max-h-[90vh] overflow-y-auto"
  >
    <div
      class="flex justify-between items-center border-b border-gray-200 pb-4 mb-4"
    >
      <h3 id="modalTitle" class="font-bold text-2xl m-0">
        Project Title
      </h3>
      <button
        id="closeModalBtn"
        class="text-gray-400 hover:text-gray-600 transition-colors bg-transparent border-none text-3xl leading-none cursor-pointer"
        aria-label="Close"
      >
        &times;
      </button>
    </div>
    <div>
      <img
        id="modalImage"
        src=""
        alt="Project Image"
        class="w-full rounded-xl mb-4 max-h-80 object-cover shadow-sm"
      />
      <p class="mb-2 text-gray-700">
        <strong class="font-semibold text-gray-800">
          Duration:
        </strong>
        <span id="modalDuration"></span>
      </p>
      <div class="mb-4">
        <strong class="font-semibold text-gray-800">
          Technologies:
        </strong>
        <div
          id="modalTechnologies"
          class="flex items-center gap-3 mt-2 text-gray-600 text-sm"
        ></div>
      </div>
      <p
        id="modalDescription"
        class="text-gray-600 leading-relaxed whitespace-pre-line m-0"
      ></p>
    </div>
  </div>
</div>